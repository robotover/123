<Window x:Class="WpfApp1.win.Klient"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1.win"
        mc:Ignorable="d"
        Title="Кабинет Клиента" Height="450" Width="700" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Content="Выйти из аккаунта" Width="120" HorizontalAlignment="Right" Margin="5" Click="BtnLogout_Click"/>

        <TabControl Grid.Row="1">
            <TabItem Header="Каталог">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
                        <TextBlock Text="Категория:" VerticalAlignment="Center" Margin="5"/>
                        <TextBox x:Name="TxtFilterCat" Width="100"/>
                        <TextBlock Text="Цена от:" VerticalAlignment="Center" Margin="5"/>
                        <TextBox x:Name="TxtPriceFrom" Width="50"/>
                        <TextBlock Text="До:" VerticalAlignment="Center" Margin="5"/>
                        <TextBox x:Name="TxtPriceTo" Width="50"/>
                        <Button Content="Фильтр" Width="80" Margin="10,0,0,0" Click="BtnFilter_Click"/>
                        <Button Content="Сбросить" Width="80" Margin="5,0,0,0" Click="BtnReset_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="DgCatalog" Grid.Row="1" IsReadOnly="True" Margin="5"/>
                    <Button Grid.Row="2" Content="Оформить заказ на выбранный товар" Height="30" Margin="5" Click="BtnOrder_Click" Foreground="Black"/>
                </Grid>
            </TabItem>

            <TabItem Header="Мои заказы и Отзывы">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="DgMyOrders" Grid.Row="0" IsReadOnly="True"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="ID товара для отзыва:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox x:Name="TxtRevProductId" Width="40" Margin="0,0,10,0"/>
                        <TextBox x:Name="TxtRevText" Width="300" Height="40" Margin="0,0,10,0" Text="Напишите отзыв..."/>
                        <Button Content="Отправить отзыв" Width="120" Click="BtnReview_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
