<Window x:Class="WpfApp1.win.Avtorizaciya"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1.win"
        mc:Ignorable="d"
        Title="Avtorizaciya" Height="400" Width="400">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="280">
            <TextBlock Text="Авторизация" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Логин:" Margin="0,0,0,5" Foreground="#555555"/>
            <TextBox x:Name="TxtLogin" Height="30" Margin="0,0,0,15" VerticalContentAlignment="Center" Padding="5,0,0,0"/>

            <TextBlock Text="Пароль:" Margin="0,0,0,5" Foreground="#555555"/>
            <PasswordBox x:Name="TxtPassword" Height="30" Margin="0,0,0,25" VerticalContentAlignment="Center" Padding="5,0,0,0"/>
        </StackPanel>
        <Button x:Name="BtnExit" Content="Выйти" Height="35" Margin="218,259,60,40" FontWeight="Bold" Click="BtnExit_Click"/>
        <Button x:Name="BtnLogin" Content="Войти" Height="35" Margin="60,259,218,40" FontWeight="Bold" Click="BtnLogin_Click"/>
    </Grid>
</Window>
