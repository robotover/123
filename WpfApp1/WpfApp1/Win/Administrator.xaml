<Window x:Class="WpfApp1.win.Administrator"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1.win"
        mc:Ignorable="d"
        Title="Панель Администратора" Height="450" Width="700" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Content="Выйти из аккаунта" Width="120" HorizontalAlignment="Right" Margin="5" Click="BtnLogout_Click"/>

        <TabControl Grid.Row="1">
            <TabItem Header="Товары (CRUD)">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="DgProducts" Grid.Row="0" IsReadOnly="True" SelectionChanged="DgProducts_SelectionChanged"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5">
                        <TextBox x:Name="TxtTitle" Width="120" Margin="5" Tag="Название"/>
                        <TextBox x:Name="TxtPrice" Width="60" Margin="5" Tag="Цена"/>
                        <TextBox x:Name="TxtStock" Width="60" Margin="5" Tag="Кол-во"/>
                        <TextBox x:Name="TxtCategory" Width="100" Margin="5" Tag="Категория"/>

                        <Button Content="Добавить" Width="70" Margin="5" Click="BtnAdd_Click"/>
                        <Button Content="Изменить" Width="70" Margin="5" Click="BtnEdit_Click"/>
                        <Button Content="Удалить" Width="70" Margin="5" Click="BtnDelete_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Пользователи и Заказы">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <DataGrid x:Name="DgUsers" Grid.Column="0" Margin="5" IsReadOnly="True"/>
                    <DataGrid x:Name="DgOrders" Grid.Column="1" Margin="5" IsReadOnly="True"/>
                </Grid>
            </TabItem>

            <TabItem Header="Отчет по продажам">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="С:" VerticalAlignment="Center" Margin="5"/>
                        <DatePicker x:Name="DpFrom" Width="120"/>
                        <TextBlock Text="По:" VerticalAlignment="Center" Margin="5"/>
                        <DatePicker x:Name="DpTo" Width="120"/>
                        <Button Content="Сформировать" Width="100" Margin="10,0,0,0" Click="BtnReport_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="DgReport" IsReadOnly="True" Height="300"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
